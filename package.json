{
  "name": "vpn-server",
  "version": "1.0.0",
  "description": "VPN Control API - device registration, usage tracking, rewards, WireGuard config distribution",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "db:migrate": "psql $DATABASE_URL -f db/schema.sql",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@googleapis/playintegrity": "^23.0.0",
    "cors": "^2.8.5",
    "pino": "^9.0.0",
    "rotating-file-stream": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "rate-limit-redis": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "pino-pretty": "^11.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}

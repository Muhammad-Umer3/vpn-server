# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL) — matches docker-compose defaults
DATABASE_URL=postgresql://vpn:vpn_secret_change_me@localhost:5432/vpn_control

# Redis (sessions, rate limiting)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-key-change-in-production
TOKEN_EXPIRY_DAYS=30

# Usage limits
DAILY_FREE_MINUTES=5
REWARD_MINUTES_PER_AD=5
REWARD_MB_PER_AD=500
DAILY_BANDWIDTH_MB=2048
MAX_REWARDS_PER_DAY=15

# WireGuard (when running on same droplet)
WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_SERVER_PUBLIC_KEY=sf4b4LWuw+clHogE0WB+qdZcDPYioqU2YXcZZhsqMU0=
WG_SERVER_ENDPOINT=146.190.160.34:51820
WG_NETWORK=10.0.0.0/24
WG_DNS=1.1.1.1

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
